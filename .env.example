# ═══════════════════════════════════════════════════════════════════════════
# loewiMMD environment template
#
# Use two local files (Vite only exposes VITE_* from frontend/.env):
#   backend/.env   — copy the "SERVER" block below
#   frontend/.env  — copy the "WEB" block below
# ═══════════════════════════════════════════════════════════════════════════

# ─── SERVER (backend/.env) ────────────────────────────────────────────────
# PORT=4000
# NODE_ENV=development
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
#
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# AUTH_GOOGLE_ONLY=true
# AUTH_REQUIRE_EMAIL_VERIFIED=true
#
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MAX_TOKENS=2048
# GROQ_TEMPERATURE=0.35
#
# AGENT_API_KEY=   # min 24 chars; see backend/.env.example for full notes

# ─── WEB (frontend/.env) — all keys MUST use VITE_ prefix ─────────────────
# VITE_API_BASE=/api
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
