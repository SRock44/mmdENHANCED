# ─── Server ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated browser origins allowed to call this API (required in production)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── Firebase Admin (Firestore + token verify) ────────────────────────────
# Project ID from Firebase console
FIREBASE_PROJECT_ID=your-project-id

# Service account (recommended for .env): create a key in GCP/IAM, paste fields
# Private key must keep literal \n for newlines in .env, or use a JSON file path instead.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES\n-----END PRIVATE KEY-----\n"

# Alternative: path to service account JSON (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=C:\secrets\firebase-service-account.json

# ─── Auth hardening (optional toggles) ───────────────────────────────────
# Set to "false" to allow non-Google Firebase providers (not recommended)
AUTH_GOOGLE_ONLY=true

# Set to "false" to allow tokens with unverified email (not recommended)
AUTH_REQUIRE_EMAIL_VERIFIED=true

# ─── Groq (server-side AI — key never sent to browsers) ─────────────────
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.35

# ─── Agent API (AI pipelines publish public graphs) ─────────────────────
# Min 24 characters. Send: Authorization: Bearer <AGENT_API_KEY> or X-Agent-Key: <key>
AGENT_API_KEY=replace-with-long-random-secret-min-24-chars
