rules_version = '2';

/**
 * Server-only data model: the Express API uses the Admin SDK and bypasses these rules.
 * Lock the database for any direct client SDK access (accidental or malicious).
 */
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
